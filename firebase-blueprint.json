{
  "entities": {
    "Supplier": {
      "title": "Supplier",
      "description": "بيانات الموردين",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "company": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "bankAccount": { "type": "string" },
        "category": { "type": "string" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "company", "createdAt"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "فواتير المشتريات",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "supplierId": { "type": "string" },
        "issueDate": { "type": "string" },
        "dueDate": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "unpaid"] },
        "notes": { "type": "string" },
        "warehouse": { "type": "string" },
        "creditNoteAmount": { "type": "number" },
        "vatRate": { "type": "number" },
        "vatAmount": { "type": "number" },
        "customVatAmount": { "type": "number" },
        "isCustomVat": { "type": "boolean" },
        "items": { "type": "array" },
        "attachments": { "type": "array" }
      },
      "required": ["id", "invoiceNumber", "supplierId", "totalAmount", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "المدفوعات والحركات المالية",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "supplierId": { "type": "string" },
        "invoiceId": { "type": "string" },
        "amount": { "type": "number" },
        "paymentDate": { "type": "string" },
        "method": { "type": "string", "enum": ["bank_transfer", "fawry", "cash", "check"] },
        "transRef": { "type": "string" }
      },
      "required": ["id", "supplierId", "invoiceId", "amount", "method", "transRef"]
    },
    "CreditNote": {
      "title": "CreditNote",
      "description": "الإشعارات الدائنة للموردين",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "creditNoteNumber": { "type": "string" },
        "supplierId": { "type": "string" },
        "amount": { "type": "number" },
        "issueDate": { "type": "string" },
        "dueDate": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "applied"] },
        "items": { "type": "array" },
        "notes": { "type": "string" },
        "attachments": { "type": "array" }
      },
      "required": ["id", "creditNoteNumber", "supplierId", "amount", "status"]
    },
    "BackupRecord": {
      "title": "BackupRecord",
      "description": "سجلات النسخ الاحتياطي",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "string" },
        "recordsCount": { "type": "object" },
        "dataDump": { "type": "string" }
      },
      "required": ["id", "timestamp", "type", "dataDump"]
    },
    "SupportMessage": {
      "title": "SupportMessage",
      "description": "رسائل الدعم والدردشة الذكية",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "role", "text", "timestamp"]
    }
  },
  "firestore": {
    "suppliers": {
      "schema": "Supplier",
      "description": "الموردين"
    },
    "invoices": {
      "schema": "Invoice",
      "description": "الفواتير"
    },
    "payments": {
      "schema": "Payment",
      "description": "المدفوعات"
    },
    "creditNotes": {
      "schema": "CreditNote",
      "description": "الإشعارات الدائنة"
    },
    "backupRecords": {
      "schema": "BackupRecord",
      "description": "النسخ الاحتياطية"
    },
    "supportMessages": {
      "schema": "SupportMessage",
      "description": "محادثات الدعم الفني"
    }
  }
}
